{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "version": 1,
  "title": "CommBank API — Overview",
  "tags": ["commbank"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Transfers completed (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(commbank_transfers_completed_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Transfers blocked (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(commbank_transfers_blocked_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Transfer throughput (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(commbank_transfers_completed_total[5m]))", "legendFormat": "completed/s", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum(rate(commbank_transfers_blocked_total[5m]))", "legendFormat": "blocked/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Transfer amount p95 (AUD)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(commbank_transfers_amount_bucket[5m])) by (le))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP request rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_request_duration_seconds_count[5m]))", "legendFormat": "requests/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
